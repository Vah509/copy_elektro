    { label: 'Кількість вводів',      value: '1, 2 або 3 введення (у т.ч. з АВР)' },
    { label: 'Апарати захисту',       value: 'Узгоджується з замовником' },
    { label: 'Збірні шини',           value: 'Мідь, алюміній — залежно від ТЗ' },
    { label: 'Однолінійна схема',     value: 'Виконується та додається у щит' },
    { label: 'Термін виготовлення',   value: 'Від 2 тижнів, узгоджується при постановці у виготовлення' },
    { label: 'Гарантія',              value: '12 місяців' },
    { label: 'Доставка',              value: 'Київ, Київська область, вся Україна' },
