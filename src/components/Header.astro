---
import { PHONE, PHONE_DISPLAY } from '../config';
const { activePage = '', lang = 'uk', altUrl = null } = Astro.props;

const prefix = lang === 'ru' ? '/ru' : '';

const nav = {
  produktsiia:    lang === 'ru' ? 'Продукция'          : 'Продукція',
  posluhy:        lang === 'ru' ? 'Услуги'             : 'Послуги',
  vykonaniRoboty: lang === 'ru' ? 'Выполненные работы' : 'Виконані роботи',
  proNas:         lang === 'ru' ? 'О нас'              : 'Про нас',
  kontakty:       lang === 'ru' ? 'Контакты'           : 'Контакти',
  cta:            lang === 'ru' ? 'Оставить заявку'    : 'Залишити заявку',
  logoName:       lang === 'ru' ? 'Сборка'             : 'Збірка',
  logoSub:        lang === 'ru' ? 'электрощитов'       : 'електрощитів',
  openMenu:       lang === 'ru' ? 'Открыть меню'       : 'Відкрити меню',
  mainNav:        lang === 'ru' ? 'Основная навигация' : 'Головна навігація',
  mobileNav:      lang === 'ru' ? 'Мобильная навигация': 'Мобільна навігація',
  callLabel:      lang === 'ru' ? `Позвонить ${PHONE_DISPLAY}` : `Зателефонувати ${PHONE_DISPLAY}`,
};

const menuProducts = [
  { href: `${prefix}/posluhy-ta-produktsiia/hrshch/`,          label: lang === 'ru' ? 'ГРЩ / ВРЩ — силовые щиты'      : 'ГРЩ / ВРЩ — силові щити' },
  { href: `${prefix}/posluhy-ta-produktsiia/dymovydalennia/`,  label: lang === 'ru' ? 'Щит дымоудаления'              : 'Щит димовидалення' },
  { href: `${prefix}/posluhy-ta-produktsiia/dvyhuny/`,         label: lang === 'ru' ? 'Управление двигателями'        : 'Керування двигунами' },
  { href: `${prefix}/posluhy-ta-produktsiia/shuz/`,            label: lang === 'ru' ? 'Управление задвижками (ШУЗ)'   : 'Керування засувками (ШУЗ)' },
  { href: `${prefix}/posluhy-ta-produktsiia/krm/`,             label: 'КРМ' },
  { href: `${prefix}/posluhy-ta-produktsiia/zenitni-lihtari/`, label: lang === 'ru' ? 'Зенитные фонари'               : 'Зенітні ліхтарі' },
  { href: `${prefix}/posluhy-ta-produktsiia/ahro/`,            label: lang === 'ru' ? 'Для агрохозяйств'              : 'Для агрогосподарств' },
];

const menuServices = [
  { href: `${prefix}/posluhy-ta-produktsiia/plk/`,            label: lang === 'ru' ? 'Программирование ПЛК'          : 'Програмування ПЛК' },
  { href: `${prefix}/posluhy-ta-produktsiia/elektromontazh/`, label: lang === 'ru' ? 'Электромонтажные работы'        : 'Електромонтажні роботи' },
];
---
<header class="em-site-header">
  <div class="em-header-inner">

    <!-- ЛОГОТИП -->
    <a href={lang === 'ru' ? '/ru/' : '/'} class="em-logo">
      <span class="em-logo-icon">
        <svg viewBox="0 0 24 24"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
      </span>
      <span class="em-logo-text">
        <span class="em-logo-name">{nav.logoName}</span>
        <span class="em-logo-sub">{nav.logoSub}</span>
      </span>
    </a>

    <!-- НАВІГАЦІЯ (десктоп) -->
    <nav aria-label={nav.mainNav}>
      <ul class="em-site-nav">
        <li class="em-dropdown">
          <a href={`${prefix}/posluhy-ta-produktsiia/`} class={activePage === 'produktsiia' ? 'active' : ''} tabindex="0">
            {nav.produktsiia}
            <svg class="em-nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </a>
          <ul class="em-dropdown-panel">
            {menuProducts.map(item => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </li>
        <li class="em-dropdown">
          <a href={`${prefix}/posluhy-ta-produktsiia/`} class={activePage === 'posluhy' ? 'active' : ''} tabindex="0">
            {nav.posluhy}
            <svg class="em-nav-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </a>
          <ul class="em-dropdown-panel">
            {menuServices.map(item => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </li>
        <li><a href={`${prefix}/vykonani-roboty/`} class={activePage === 'vykonani-roboty' ? 'active' : ''}>{nav.vykonaniRoboty}</a></li>
        <li><a href={`${prefix}/pro-nas/`}         class={activePage === 'pro-nas'         ? 'active' : ''}>{nav.proNas}</a></li>
        <li><a href={`${prefix}/kontakty/`}         class={activePage === 'kontakty'         ? 'active' : ''}>{nav.kontakty}</a></li>
      </ul>
    </nav>

    <!-- ПЕРЕКЛЮЧАТЕЛЬ ЯЗЫКА — десктоп (≥901px), между nav и header-right -->
    <!-- Скрыт на мобильном через CSS: .em-lang-switch { display:none } @media ≤900px -->
    {altUrl && (
      <div class="em-lang-switch">
        {lang === 'uk' ? (
          <span class="em-lang-active">УКР</span>
        ) : (
          <a href={altUrl} class="em-lang-link">УКР</a>
        )}
        <span class="em-lang-sep" aria-hidden="true"></span>
        {lang === 'ru' ? (
          <span class="em-lang-active">РУС</span>
        ) : (
          <a href={altUrl} class="em-lang-link">РУС</a>
        )}
      </div>
    )}

    <!-- ПРАВА ЧАСТИНА: телефон + CTA + гамбургер -->
    <div class="em-header-right">
      <a href={`tel:${PHONE}`} class="em-header-phone" aria-label={nav.callLabel}>
        <svg class="em-phone-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z"/></svg>
        <span class="em-header-phone-number">{PHONE_DISPLAY}</span>
      </a>
      <a href="#kontakty-blok" class="em-header-cta">{nav.cta}</a>
      <button type="button" class="em-burger" aria-label={nav.openMenu} aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>

  <!-- МОБІЛЬНЕ МЕНЮ (гамбургер) -->
  <nav class="em-mobile-nav" aria-label={nav.mobileNav}>
    <button type="button" class="em-mobile-toggle active" aria-expanded="false" aria-controls="mobile-sub-produktsiia">
      {nav.produktsiia}
      <svg class="em-mobile-toggle-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <div class="em-mobile-sub" id="mobile-sub-produktsiia">
      {menuProducts.map(item => (
        <a href={item.href}>— {item.label}</a>
      ))}
    </div>

    <button type="button" class="em-mobile-toggle" aria-expanded="false" aria-controls="mobile-sub-posluhy">
      {nav.posluhy}
      <svg class="em-mobile-toggle-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </button>
    <div class="em-mobile-sub" id="mobile-sub-posluhy">
      {menuServices.map(item => (
        <a href={item.href}>— {item.label}</a>
      ))}
    </div>

    <a href={`${prefix}/vykonani-roboty/`}>{nav.vykonaniRoboty}</a>
    <a href={`${prefix}/pro-nas/`}>{nav.proNas}</a>
    <a href={`${prefix}/kontakty/`}>{nav.kontakty}</a>

    <!-- ПЕРЕКЛЮЧАТЕЛЬ ЯЗЫКА — в конце гамбургер-меню, только если есть altUrl -->
    {altUrl && (
      <div class="em-mobile-lang">
        <hr class="em-mobile-lang-sep" />
        <div class="em-mobile-lang-row">
          {lang === 'uk' ? (
            <span class="em-lang-active">УКР</span>
          ) : (
            <a href={altUrl} class="em-lang-link">УКР</a>
          )}
          <span class="em-mobile-lang-divider" aria-hidden="true">|</span>
          {lang === 'ru' ? (
            <span class="em-lang-active">РУС</span>
          ) : (
            <a href={altUrl} class="em-lang-link">РУС</a>
          )}
        </div>
      </div>
    )}
  </nav>
</header>
